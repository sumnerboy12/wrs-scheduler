# Copy this file to .env (same folder) and fill in your SMTP details to
# enable the Schedule > Summaries > email feature. Leave .env missing
# entirely and email sending just stays disabled — nothing else breaks.
#
# Any SMTP-capable mailbox works, e.g. your business email account, or a
# transactional provider like Resend/SendGrid/Postmark's SMTP endpoint.

SMTP_HOST=
SMTP_PORT=587
# true if your provider requires SSL on connect (usually port 465); most
# providers use STARTTLS on 587 instead, which is "false" here.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional — defaults to SMTP_USER if left blank.
SMTP_FROM=
# Optional — where replies should land if it's different from SMTP_FROM
# (e.g. sending via a transactional provider's domain but wanting replies
# to go to a real mailbox).
SMTP_REPLY_TO=
