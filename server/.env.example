# Copy this file to .env (same folder) and fill in your SMTP details to
# enable the Schedule > Summaries > email feature. Leave .env missing
# entirely and email sending just stays disabled — nothing else breaks.
#
# Any SMTP-capable mailbox works, e.g. your business email account, or a
# transactional provider like Resend/SendGrid/Postmark's SMTP endpoint.

SMTP_HOST=
SMTP_PORT=587
# true if your provider requires SSL on connect (usually port 465); most
# providers use STARTTLS on 587 instead, which is "false" here.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional — defaults to SMTP_USER if left blank.
SMTP_FROM=
# Optional — display name shown alongside SMTP_FROM, e.g. "Jesse Wayman"
# so emails show as `Jesse Wayman <jesse@waymanroofing.co.nz>` instead of
# just the bare address.
SMTP_FROM_NAME=
# Optional — where replies should land if it's different from SMTP_FROM
# (e.g. sending via a transactional provider's domain but wanting replies
# to go to a real mailbox).
SMTP_REPLY_TO=

# Optional — enables a "Sign in with SSO" button via any OpenID Connect
# provider (e.g. Microsoft Entra ID / Azure AD). Leave these blank and only
# the username/password login shows.
#
# SSO does NOT create accounts on its own — a user must already exist under
# Users with an Email set that matches their identity provider's email
# (case-insensitive) before their SSO sign-in will succeed.
#
# OIDC_ISSUER_URL is the provider's issuer/authority, e.g. for Entra ID:
#   https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_REDIRECT_URI must exactly match what's registered with the provider,
# e.g. https://rostr.example.com/api/auth/oidc/callback
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# Optional — periodically imports approved leave from an external calendar
# feed (any payroll/HR system that can publish one as an iCalendar (.ics)
# URL — what we've tested against so far happens to be Lentune's, but this
# isn't specific to it) into Rostr's own Leave records. Leave blank to
# disable entirely — nothing else is affected. The URL usually embeds an
# access token as part of the path/query, so treat it as a secret exactly
# like a password: only ever in this .env file, never committed or shared.
#
# Matching is by employee NAME (the feed carries no email/id) — exact,
# case-insensitive. A name Rostr can't match to an employee is skipped and
# logged, not guessed at. Only leave already approved (or processed) is
# imported; Draft/Submitted requests are left out since they're not a
# commitment yet. Public Holiday entries are skipped too — Rostr already
# shows NZ public holidays on the Schedule itself.
LEAVE_CALENDAR_URL=
# Optional — how often to re-check the feed, in minutes. Defaults to 60.
LEAVE_SYNC_INTERVAL_MINUTES=60
